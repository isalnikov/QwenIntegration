<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE filesystem PUBLIC "-//NetBeans//DTD Filesystem 1.2//EN" "http://www.netbeans.org/dtds/filesystem-1_2.dtd">
<filesystem>
    <!-- Display names for Menu and Toolbar folders (used by @ActionReference) -->
    <folder name="Menu">
        <folder name="Qwen">
            <attr name="displayName" bundlevalue="org.netbeans.modules.qwen.Bundle#Menu/Qwen" />
        </folder>
    </folder>
    <folder name="Toolbars">
        <folder name="Qwen">
            <attr name="displayName" bundlevalue="org.netbeans.modules.qwen.Bundle#Toolbars/Qwen" />
        </folder>
    </folder>
</filesystem>
