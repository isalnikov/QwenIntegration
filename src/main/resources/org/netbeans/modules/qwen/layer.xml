            <file name="Security.shadow">
                <attr name="originalFile" stringvalue="Actions/Qwen/org-netbeans-modules-qwen-ui-QwenAction-SecurityAction.instance"/>
                <attr name="position" intvalue="500"/>
            </file>

            <!-- Separator -->
            <file name="sep1.instance">
                <attr name="instanceClass" stringvalue="javax.swing.JSeparator"/>
                <attr name="position" intvalue="550"/>
