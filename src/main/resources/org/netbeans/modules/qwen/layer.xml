<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE filesystem PUBLIC "-//NetBeans//DTD Filesystem 1.2//EN" "http://www.netbeans.org/dtds/filesystem-1_2.dtd">
<filesystem>

    <!-- ========== STEP 1: Register all Actions in Actions/ folder ========== -->
    <folder name="Actions">
        <folder name="Qwen">
            <attr name="displayName" bundlevalue="org.netbeans.modules.qwen.Bundle#menu.name" />

            <file name="org-netbeans-modules-qwen-ui-QwenAction-ExplainAction.instance">
                <attr name="instanceCreate" newvalue="org.netbeans.modules.qwen.ui.QwenAction$Explain"/>
            </file>
            <file name="org-netbeans-modules-qwen-ui-QwenAction-GenerateAction.instance">
                <attr name="instanceCreate" newvalue="org.netbeans.modules.qwen.ui.QwenAction$Generate"/>
            </file>
            <file name="org-netbeans-modules-qwen-ui-QwenAction-RefactorAction.instance">
                <attr name="instanceCreate" newvalue="org.netbeans.modules.qwen.ui.QwenAction$Refactor"/>
            </file>
            <file name="org-netbeans-modules-qwen-ui-QwenAction-TestAction.instance">
                <attr name="instanceCreate" newvalue="org.netbeans.modules.qwen.ui.QwenAction$Test"/>
            </file>
            <file name="org-netbeans-modules-qwen-ui-QwenAction-SecurityAction.instance">
                <attr name="instanceCreate" newvalue="org.netbeans.modules.qwen.ui.QwenAction$Security"/>
            </file>
            <file name="org-netbeans-modules-qwen-ui-QwenAction-AgentAction.instance">
                <attr name="instanceCreate" newvalue="org.netbeans.modules.qwen.ui.QwenAction$Agent"/>
            </file>
            <file name="org-netbeans-modules-qwen-ui-QwenAction-ConsoleAction.instance">
                <attr name="instanceCreate" newvalue="org.netbeans.modules.qwen.ui.QwenAction$OpenConsole"/>
            </file>
        </folder>
    </folder>

    <!-- ========== STEP 2: Main menu bar — Qwen AI ========== -->
    <folder name="Menu">
        <folder name="QwenAI">
            <attr name="displayName" bundlevalue="org.netbeans.modules.qwen.Bundle#menu.name" />
            <attr name="position" intvalue="350"/>

            <file name="Explain.shadow">
                <attr name="originalFile" stringvalue="Actions/Qwen/org-netbeans-modules-qwen-ui-QwenAction-ExplainAction.instance"/>
